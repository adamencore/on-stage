---
import { formatPerformanceRange, formatPerformanceRangeShort } from '../data/events.js';

const { event, variant = 'default' } = Astro.props;
const dateLabel = formatPerformanceRange(event);
const dateShort = formatPerformanceRangeShort(event);
const performanceCount = event.performances.length;
const hasImage = Boolean(event.image);
---

<article class:list={['event-card', `event-card--${variant}`, { 'event-card--has-image': hasImage }]}>
  <a href={event.url} class="event-card__link" aria-label={`${event.title} — ${dateLabel}`}>
    <div class="event-card__visual" aria-hidden={hasImage ? undefined : 'true'}>
      {hasImage ? (
        <img
          src={event.image}
          alt={event.imageAlt || `${event.title} — ${event.organization.name}`}
          class="event-card__image"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <>
          <span class="event-card__visual-org">{event.organization.shortName}</span>
          <span class="event-card__visual-title">{event.title}</span>
        </>
      )}
    </div>

    <div class="event-card__body">
      <div class="event-card__meta">
        <span class="tag">{event.category}</span>
        <span class="event-card__org">{event.organization.shortName}</span>
      </div>

      <h3 class="event-card__title">{event.title}</h3>

      <p class="event-card__date">
        {dateLabel}
        {performanceCount > 1 && (
          <span class="event-card__date-suffix">· {performanceCount} performances</span>
        )}
      </p>

      <p class="event-card__desc">{event.shortDescription}</p>

      <span class="event-card__cta">
        Event details
        <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
          <path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </span>
    </div>
  </a>
</article>

<style>
  .event-card {
    background: var(--bg-card);
    border: 1px solid var(--rule);
    border-radius: var(--radius-m);
    overflow: hidden;
    transition: border-color 240ms ease, transform 240ms ease, box-shadow 240ms ease;
    height: 100%;
    display: flex;
  }

  .event-card:hover {
    border-color: var(--ink);
    transform: translateY(-2px);
    box-shadow: 0 12px 32px -20px rgba(26, 22, 20, 0.25);
  }

  .event-card__link {
    color: inherit;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    height: 100%;
    width: 100%;
  }

  .event-card__visual {
    position: relative;
    aspect-ratio: 1 / 1;
    background: var(--bg-deep);
    background-image:
      radial-gradient(circle at 20% 30%, color-mix(in srgb, var(--accent) 10%, transparent), transparent 50%),
      radial-gradient(circle at 80% 70%, color-mix(in srgb, var(--ink) 6%, transparent), transparent 55%);
    border-bottom: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding: var(--space-l);
    overflow: hidden;
  }

  .event-card--has-image .event-card__visual {
    padding: 0;
    background: var(--bg-deep);
  }

  .event-card__visual::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: linear-gradient(120deg, transparent 0%, transparent 60%, color-mix(in srgb, var(--accent) 7%, transparent) 100%);
    pointer-events: none;
  }

  .event-card--has-image .event-card__visual::after {
    display: none;
  }

  .event-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 600ms ease;
  }

  .event-card:hover .event-card__image {
    transform: scale(1.02);
  }

  .event-card__visual-org {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent-deep);
    font-weight: 500;
    margin-bottom: 0.6rem;
    z-index: 1;
  }

  .event-card__visual-title {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 1.2rem + 1.5vw, 2.2rem);
    line-height: 1.05;
    color: var(--ink);
    font-weight: 450;
    letter-spacing: -0.015em;
    max-width: 95%;
    z-index: 1;
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
  }

  .event-card__body {
    padding: var(--space-m) var(--space-m) var(--space-l);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    flex: 1;
  }

  .event-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-s);
    margin-bottom: 0.25rem;
  }

  .event-card__org {
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-mute);
    font-weight: 500;
  }

  .event-card__title {
    font-size: var(--step-2);
    line-height: 1.15;
    margin: 0;
  }

  .event-card__date {
    font-size: 0.92rem;
    color: var(--ink-soft);
    margin: 0;
    font-weight: 500;
  }

  .event-card__date-suffix {
    color: var(--ink-mute);
    font-weight: 400;
  }

  .event-card__desc {
    font-size: 0.94rem;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0;
    flex: 1;
  }

  .event-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.74rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink);
    margin-top: var(--space-s);
    padding-top: var(--space-s);
    border-top: 1px solid var(--rule-soft);
    transition: color 200ms ease, gap 200ms ease;
  }

  .event-card:hover .event-card__cta {
    color: var(--accent-deep);
    gap: 0.85rem;
  }

  /* Featured (larger) variant for the home hero row */
  .event-card--featured .event-card__title {
    font-size: var(--step-3);
  }

  /* Compact variant for organization pages and lists */
  .event-card--compact .event-card__visual {
    aspect-ratio: 1 / 1;
    padding: var(--space-m);
  }

  .event-card--compact .event-card__visual-title {
    font-size: clamp(1.3rem, 1rem + 1vw, 1.7rem);
  }

  .event-card--compact .event-card__body {
    padding: var(--space-s) var(--space-m) var(--space-m);
  }

  .event-card--compact .event-card__title {
    font-size: var(--step-1);
  }
</style>
