---
import Base from '../../layouts/Base.astro';
import EventCard from '../../components/EventCard.astro';
import { organizations } from '../../data/organizations.js';
import { getEventsByOrganization } from '../../data/events.js';

export async function getStaticPaths() {
  return organizations.map((org) => ({
    params: { slug: org.slug },
    props: { org },
  }));
}

const { org } = Astro.props;
const events = getEventsByOrganization(org.slug);
const upcoming = events.filter((e) => e.isUpcoming);
const past = events.filter((e) => !e.isUpcoming);

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'PerformingGroup',
  name: org.name,
  url: org.website,
  description: org.description,
  location: {
    '@type': 'Place',
    name: 'Electric Theater',
    address: {
      '@type': 'PostalAddress',
      streetAddress: '68 E Tabernacle St',
      addressLocality: 'St. George',
      addressRegion: 'UT',
      postalCode: '84770',
      addressCountry: 'US',
    },
  },
};
---

<Base
  title={org.name}
  description={`${org.name} is a resident performing arts organization at the Electric Theater in St. George, Utah. ${org.description}`}
  jsonLd={orgSchema}
>
  <section class="org-hero">
    <div class="container org-hero__inner">
      <a href="/organizations/" class="org-hero__back">← All organizations</a>
      <p class="eyebrow eyebrow--accent">{org.category} · Resident company</p>
      <h1 class="org-hero__name">{org.name}</h1>
      <p class="org-hero__tagline">{org.tagline}</p>

      <p class="org-hero__desc">{org.longDescription}</p>

      <div class="org-hero__actions">
        <a href={org.website} class="btn btn--ghost" target="_blank" rel="noopener">
          Visit {org.shortName} ↗
        </a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow eyebrow--accent">Upcoming</p>
          <h2>{org.shortName}'s upcoming performances</h2>
        </div>
      </div>

      {upcoming.length > 0 ? (
        <div class="org-events-grid">
          {upcoming.map((event) => <EventCard event={event} />)}
        </div>
      ) : (
        <div class="empty-state">
          <p>No upcoming events from {org.shortName} are listed yet. Check back soon, or visit <a href={org.website} target="_blank" rel="noopener">{org.shortName}'s website ↗</a>.</p>
        </div>
      )}

      {past.length > 0 && (
        <div class="past-section">
          <h3 class="past-section__heading">Recent productions</h3>
          <ul class="past-list">
            {past.map((event) => (
              <li>
                <a href={event.url}>{event.title}</a>
                <span>·</span>
                <time datetime={event.firstPerformance.startISO}>
                  {new Intl.DateTimeFormat('en-US', { month: 'long', year: 'numeric', timeZone: 'America/Denver' }).format(event.firstPerformance.start)}
                </time>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </section>
</Base>

<style>
  .org-hero {
    padding-block: var(--space-2xl) var(--space-xl);
    border-bottom: 1px solid var(--rule);
    background: var(--bg-deep);
  }

  .org-hero__inner {
    max-width: 820px;
  }

  .org-hero__back {
    font-size: 0.78rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-soft);
    text-decoration: none;
    font-weight: 500;
    display: inline-block;
    margin-bottom: var(--space-l);
  }

  .org-hero__back:hover {
    color: var(--accent-deep);
  }

  .org-hero__name {
    font-size: var(--step-6);
    line-height: 1.05;
    margin: var(--space-s) 0;
  }

  .org-hero__tagline {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--step-2);
    color: var(--ink-soft);
    margin: 0 0 var(--space-l);
    max-width: 40ch;
    line-height: 1.3;
    font-variation-settings: 'opsz' 144, 'SOFT' 60;
  }

  .org-hero__desc {
    font-size: var(--step-0);
    line-height: 1.7;
    color: var(--ink-soft);
    max-width: 60ch;
    margin: 0 0 var(--space-l);
  }

  .org-hero__actions {
    display: flex;
    gap: var(--space-s);
  }

  .org-events-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-l);
  }

  .empty-state {
    padding: var(--space-2xl) var(--space-l);
    text-align: center;
    color: var(--ink-mute);
    border: 1px dashed var(--rule);
    border-radius: var(--radius-m);
  }

  .past-section {
    margin-top: var(--space-2xl);
    padding-top: var(--space-l);
    border-top: 1px solid var(--rule);
  }

  .past-section__heading {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 0 0 var(--space-m);
  }

  .past-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .past-list li {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    padding: 0.4rem 0;
    color: var(--ink-mute);
    font-size: 0.92rem;
  }

  .past-list a {
    color: var(--ink-soft);
    font-weight: 500;
  }
</style>
